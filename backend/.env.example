# Backend environment variable reference.
# Copy this file to `.env` (which is gitignored) and fill in real values.
#
# JWT_SECRET                  Secret used to sign authentication tokens (HS256).
# FRONTEND_ORIGIN             Frontend origin allowed for credentialed CORS.
# FIREBASE_SERVICE_ACCOUNT_PATH  Path to the Firebase admin SDK JSON credentials.

JWT_SECRET=
FRONTEND_ORIGIN=http://localhost:5173
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
